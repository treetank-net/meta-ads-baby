{
  "description": "Google Ads Baby safety gate. Blocks confirm_mutation until the user replies with the safe word.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "google-ads__(?:prepare_|confirm_)",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/safety-hook.js\" pre-tool"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/safety-hook.js\" user-submit"
          }
        ]
      }
    ]
  }
}
